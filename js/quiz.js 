console.log("🟢 JS CHARGÉ");

window.onload = () => {
  console.log("🟢 WINDOW ONLOAD OK");

  const letters = [
    { letter: "ܐ", answer: "Alap" },
    { letter: "ܒ", answer: "Beith" },
    { letter: "ܓ", answer: "Gamal" },
    { letter: "ܕ", answer: "Dalath" }
  ];

  const quizLetter = document.getElementById("quiz-letter");
  const quizAnswers = document.getElementById("quiz-answers");

  console.log("quizLetter =", quizLetter);
  console.log("quizAnswers =", quizAnswers);

  if (!quizLetter || !quizAnswers) {
    alert("❌ DOM NON TROUVÉ (IDs faux ou script trop tôt)");
    return;
  }

  const current = letters[0];

  quizLetter.textContent = current.letter;
  quizAnswers.innerHTML = "";

  console.log("🟡 création boutons...");

  for (let i = 0; i < letters.length; i++) {
    const btn = document.createElement("button");
    btn.textContent = letters[i].answer;

    btn.style.display = "block";
    btn.style.margin = "10px";
    btn.style.padding = "10px";

    quizAnswers.appendChild(btn);

    console.log("bouton ajouté:", letters[i].answer);
  }

  console.log("🟢 FIN BOUCLE");
};