/* =========================
   ALPHABET DATA
========================= */

const letters = [

  { syr: "ܐ", latin: "A" },
  { syr: "ܒ", latin: "B" },
  { syr: "ܓ", latin: "G" },
  { syr: "ܕ", latin: "D" },
  { syr: "ܗ", latin: "H" },
  { syr: "ܘ", latin: "W" },
  { syr: "ܙ", latin: "Z" },
  { syr: "ܚ", latin: "Ḥ" },
  { syr: "ܛ", latin: "Ṭ" },
  { syr: "ܝ", latin: "Y" },
  { syr: "ܟ", latin: "K" },
  { syr: "ܠ", latin: "L" },
  { syr: "ܡ", latin: "M" },
  { syr: "ܢ", latin: "N" },
  { syr: "ܣ", latin: "S" },
  { syr: "ܥ", latin: "ʿ" },
  { syr: "ܦ", latin: "P" },
  { syr: "ܨ", latin: "Ṣ" },
  { syr: "ܩ", latin: "Q" },
  { syr: "ܪ", latin: "R" },
  { syr: "ܫ", latin: "SH" },
  { syr: "ܬ", latin: "T" }

];

/* =========================
   VARIABLES
========================= */

let currentQuestion;
let score = 0;
let xp = 0;

/* =========================
   DOM
========================= */

const syrLetter =
  document.getElementById("quiz-letter");

const answersContainer =
  document.getElementById("quiz-answers");

const scoreText =
  document.getElementById("score");

const xpText =
  document.getElementById("xp");

/* =========================
   RANDOM
========================= */

function randomLetter() {

  return letters[
    Math.floor(Math.random() * letters.length)
  ];

}

/* =========================
   SHUFFLE
========================= */

function shuffle(array) {

  return array.sort(() => Math.random() - 0.5);

}

/* =========================
   NEW QUESTION
========================= */

function generateQuestion() {

  answersContainer.innerHTML = "";

  currentQuestion = randomLetter();

  syrLetter.textContent =
    currentQuestion.syr;

  let answers = [currentQuestion.latin];

  while (answers.length < 4) {

    let random =
      randomLetter().latin;

    if (!answers.includes(random)) {

      answers.push(random);

    }

  }

  answers = shuffle(answers);

  answers.forEach(answer => {

    const btn =
      document.createElement("button");

    btn.classList.add("quiz-btn");

    btn.textContent = answer;

    btn.onclick = () =>
      checkAnswer(answer);

    answersContainer.appendChild(btn);

  });

}

/* =========================
   CHECK ANSWER
========================= */

function checkAnswer(answer) {

  if (answer === currentQuestion.latin) {

    score++;

    xp += 10;

    alert("✅ Bonne réponse !");

  } else {

    alert(
      `❌ Mauvaise réponse !
La bonne réponse était :
${currentQuestion.latin}`
    );

  }

  scoreText.textContent = score;
  xpText.textContent = xp;

  generateQuestion();

}

/* =========================
   START
========================= */

generateQuestion();