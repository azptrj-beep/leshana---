const letters = [
  { letter: "ܐ", answer: "Alap" },
  { letter: "ܒ", answer: "Beith" },
  { letter: "ܓ", answer: "Gamal" },
  { letter: "ܕ", answer: "Dalath" }
];

let score = 0;
let xp = 0;

const quizLetter = document.querySelector("#quiz-letter");
const quizAnswers = document.querySelector("#quiz-answers");
const scoreEl = document.querySelector("#score");
const xpEl = document.querySelector("#xp");

function loadQuestion() {

  const current = letters[Math.floor(Math.random() * letters.length)];

  quizLetter.innerHTML = current.letter;
  quizAnswers.innerHTML = "";

  const shuffled = [...letters].sort(() => Math.random() - 0.5);

  shuffled.forEach(item => {

    const btn = document.createElement("button");
    btn.className = "quiz-btn";
    btn.textContent = item.answer;

    btn.onclick = () => {

      if (item.answer === current.answer) {
        score++;
        xp += 10;

        scoreEl.textContent = score;
        xpEl.textContent = xp;

        alert("✅ Bonne réponse");
      } else {
        alert("❌ Mauvaise réponse");
      }

      loadQuestion();
    };

    quizAnswers.appendChild(btn);
  });
}

window.onload = loadQuestion;