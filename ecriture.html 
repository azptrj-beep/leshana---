<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Écriture Soureth Guidée</title>

<style>

body{
  margin:0;
  font-family:Arial;
  background:#f4f7ff;
  text-align:center;
}

/* HEADER */
header{
  background:#0033a0;
  color:white;
  padding:15px;
}

/* CARD */
.card{
  margin:20px;
  padding:20px;
  background:white;
  border-radius:18px;
  box-shadow:0 5px 20px rgba(0,0,0,0.1);
}

/* LETTRE */
#letterDisplay{
  font-size:90px;
  color:#0033a0;
  margin:10px;
  direction:rtl;
}

/* CANVAS WRAPPER */
.wrapper{
  position:relative;
  width:90vw;
  max-width:350px;
  margin:auto;
}

/* CANVAS */
canvas{
  width:100%;
  height:350px;
  border:3px solid #0033a0;
  border-radius:18px;
  touch-action:none;
  background:white;
}

/* GUIDE */
#guide{
  position:absolute;
  top:50%;
  left:50%;
  transform:translate(-50%,-50%);
  font-size:160px;
  opacity:0.08;
  pointer-events:none;
  direction:rtl;
}

/* BUTTONS */
button{
  padding:10px 15px;
  margin:8px;
  border:none;
  border-radius:10px;
  background:#0033a0;
  color:white;
}

/* RESULT */
#result{
  font-size:20px;
  margin-top:10px;
}

.good{ color:green; }
.bad{ color:red; }

</style>
</head>

<body>

<header>
<h1>✍️ Écriture Soureth Guidée</h1>
</header>

<div class="card">

<div id="letterDisplay">ܐ</div>

<div class="wrapper">
  <div id="guide">ܐ</div>
  <canvas id="canvas"></canvas>
</div>

<button onclick="clearCanvas()">Effacer</button>
<button onclick="nextLetter()">Lettre suivante</button>

<div id="result"></div>

</div>

<script>

const letters = ["ܐ","ܒ","ܓ","ܕ","ܗ","ܘ","ܙ","ܚ","ܛ","ܝ","ܟ","ܠ","ܡ","ܢ","ܣ","ܥ","ܦ","ܨ","ܩ","ܪ","ܫ","ܬ"];

let index = 0;

const canvas = document.getElementById("canvas");
const ctx = canvas.getContext("2d");

let drawing = false;

/* 🔥 resize FIX (IMPORTANT) */
function resize(){
  canvas.width = canvas.offsetWidth;
  canvas.height = canvas.offsetHeight;
}
window.addEventListener("resize", resize);
resize();

/* LETTRE */
function setLetter(){
  document.getElementById("letterDisplay").innerText = letters[index];
  document.getElementById("guide").innerText = letters[index];
}
setLetter();

/* DRAW */
function pos(e){
  const r = canvas.getBoundingClientRect();
  const t = e.touches?.[0];
  return {
    x:(t?t.clientX:e.clientX)-r.left,
    y:(t?t.clientY:e.clientY)-r.top
  };
}

canvas.addEventListener("pointerdown", e=>{
  drawing = true;
  const p = pos(e);
  ctx.beginPath();
  ctx.moveTo(p.x,p.y);
});

canvas.addEventListener("pointermove", e=>{
  if(!drawing) return;
  const p = pos(e);
  ctx.lineWidth = 6;
  ctx.lineCap = "round";
  ctx.strokeStyle="#0033a0";
  ctx.lineTo(p.x,p.y);
  ctx.stroke();
});

canvas.addEventListener("pointerup", ()=>drawing=false);

/* CLEAR */
function clearCanvas(){
  ctx.clearRect(0,0,canvas.width,canvas.height);
}

/* NEXT LETTER + SIMPLE IA CHECK */
function nextLetter(){

  const score = Math.random(); 
  // 👉 IA SIMULÉE (version 1)
  // on peut remplacer par vraie analyse ensuite

  if(score > 0.5){
    document.getElementById("result").innerHTML =
      "✔ Correct !";
    document.getElementById("result").className = "good";
  } else {
    document.getElementById("result").innerHTML =
      "✘ Recommence";
    document.getElementById("result").className = "bad";
  }

  index++;
  if(index >= letters.length) index = 0;

  setLetter();
  clearCanvas();
}

</script>

</body>
</html>